#!/usr/bin/env bash
set -euo pipefail

if ! command -v exiftool >/dev/null 2>&1; then
  echo "✗ exiftool is required by the pre-commit maintenance scripts."
  echo "  macOS:  brew bundle  (or: brew install exiftool)"
  echo "  Linux:  sudo apt-get install -y libimage-exiftool-perl"
  exit 1
fi

# Maintenance scripts — keep generated artifacts (favicons, srcset, EXIF,
# lighthouse configs) up to date.
#
# Ordering matters: embed-copyright runs BEFORE optimize-images so that the
# srcset variants generated by sharp inherit the just-written EXIF/XMP from
# their source files (via keepExif/keepXmp in optimize-images.mjs). If we
# reversed the order, optimize-images would skip variants whose mtime is newer
# than the source — but then embed-copyright would bump the source's mtime,
# leaving the variants stale until the NEXT commit's optimize-images run.
node scripts/pipeline/embed-copyright.mjs
node scripts/pipeline/optimize-images.mjs
node scripts/pipeline/generate-favicons.mjs
node scripts/pipeline/generate-lighthouse-config.mjs
# OG variants run AFTER optimize-images so they pick up the freshly written
# EXIF/XMP on the source files. Generates 1200×630 blurred self-fill variants
# from every portrait image so LinkedIn / Facebook / WhatsApp social cards
# render the album's actual cover instead of falling back to fondo-paisaje.
node scripts/pipeline/generate-og-images.mjs

# Re-stage any tracked files the scripts modified plus any newly generated assets.
git add -u
git add static/srcset static/favicon static/favicon.ico static/og 2>/dev/null || true

# Verify every image path in src/data/ resolves to a file in static/.
# Catches typos and dangling refs the moment Arena renames or deletes a file
# but forgets to update the JSON that points at it.
npm run check:images

# Verify every t()/tObject() key in code exists in BOTH en.json and es.json,
# the two JSONs are key-for-key parity, and there are no orphans. Catches a
# new t() call without the matching JSON entry, a deleted call site that
# leaves stale translations behind, and EN/ES drift.
npm run check:i18n

# Apply every Sveltia CMS `pattern` validator to actual data files. The CMS
# UI enforces these at edit time; this catches hand-edits or pre-pattern
# legacy content that the UI would have rejected (e.g. an over-length
# OG description that will truncate on Google SERP / social cards).
npm run check:cms

# Fork-readiness gate (AUDIT_CHECKLIST.md #18). Verifies that framework code
# in src/{lib,routes,params} stays free of per-site literals: brand strings,
# hex colors, hardcoded section IDs, hardcoded BCP-47/OG locale codes. Also
# verifies all 7 config files exist for every language in sitio.json.
# Protects the multi-site abstraction layer from silent regression.
npm run check:fork

# Required-config gate (AUDIT_CHECKLIST.md #18.9). Walks the merged config
# (DEFAULTS deep-merged with per-locale JSON) and fails on any surviving
# REQUIRED("hint") sentinel — catches the failure mode where a fork forgets
# to fill in a load-bearing field like siteConfig.name or seoConfig.description.
# Companion to check:fork (which only verifies the JSON files exist).
npm run check:required-config

# Frontmatter schema (AUDIT_CHECKLIST.md #10.11). Validates every escritos/*.md
# and paginas/*.md against a per-collection schema (required fields, type
# constraints, enum values). Catches `tepmlate:` typos and silently-missing
# required fields that the CMS UI would have rejected.
npm run check:frontmatter

# Pre-commit ↔ CI gate parity (AUDIT_CHECKLIST.md #13.15). Extracts every
# `npm run X` invocation from this file and from ci.yml; asserts the
# verification-gate set is symmetric so a new gate can't be added to one
# place and forgotten in the other.
npm run check:ci-parity

# Node version pin parity (AUDIT_CHECKLIST.md #1.13). Asserts the major
# Node version matches across .nvmrc, package.json#engines.node, Brewfile,
# and every workflow's setup-node step. Prevents local-vs-CI bugs from
# version drift after a Node bump.
npm run check:node-pin

# Audit-checklist structural integrity. Asserts row IDs are unique, section
# numbers monotonic, and every cross-reference resolves. Catches subtle rot
# in AUDIT_CHECKLIST.md before it ships.
npm run check:audit-doc

# Orphan-image sweep (warn-only by default). Reports images under
# static/media/ with zero references in source. Pass --strict to fail on
# orphans (don't enable in pre-commit; surface for cleanup).
npm run check:orphan-images

# Navegacion key ↔ paginas slug parity. Every `navegacion.json#items[].key`
# must resolve to a real page under src/data/paginas/{lang}/. Catches typos
# like `"sobre_mi"` that would silently render a navbar link to a 404
# (buildNavItems falls back to using the key as the path).
npm run check:nav-slugs

# Required paginas integrity. The 4 system page-IDs (homePage, writingPageId,
# portfolioPageId, privacyPageId) must each have a corresponding active
# paginas markdown file in every configured language. Without this gate, a
# fork can delete src/data/paginas/<lang>/inicio.md without bumping
# sitio.json#homePage and only discover the broken root route at user-visit
# time. Parallel to check:nav-slugs.
npm run check:required-paginas

# Portfolio photos[].src parity across locales. The CMS schema declares
# `photos: i18n: duplicate` so Sveltia mirrors the array shape — but a
# hand-edit or a temporary schema regression can re-introduce drift where
# ES and EN photos arrays differ in length, order, or src paths. Caught
# this exact bug once (parada-de-manos + retrato-formal had different
# photo order per locale). Asserts identical length + order + src per album.
npm run check:portfolio-parity

# Per-album image-weight budget. Catches "uploaded a 12 MB raw export" or a
# bloated cover before it lands in git history. Source bytes only — srcset
# variants generated by sharp inherit from these but stay much smaller.
npm run check:album-weight

# Dependency-license audit. Walks the production dependency tree and fails
# on any package whose license isn't on the permissive allowlist (MIT, ISC,
# Apache-2.0, BSD, OFL-1.1, etc.). Catches a transitive GPL/AGPL dep
# before it becomes a legal problem for the bundled JS we ship.
npm run check:licenses

# GitHub Actions SHA-pin enforcer. Asserts every `uses: org/repo@<ref>` in
# .github/workflows/ pins to a 40-char commit SHA instead of a mutable tag
# (@v6, @main). Tag pinning is a real supply-chain attack vector — a
# compromised maintainer can force-push under an existing tag and our CI
# silently pulls in the malicious code. SHAs are immutable.
npm run check:actions-pinned

# CI parity — fail locally for the same things ci.yml would reject.
npm run check
npm run lint
npm run format:check

# Spell check via cspell. Catches typos in comments, JSON labels, markdown docs,
# and string literals. Project-specific terms (brand names, library names,
# Spanish words, JSON field names) live in `cspell-words.txt`; framework /
# config behaviour lives in `cspell.json`. New typo in a comment? Either fix it
# or add the word to `cspell-words.txt` (only for real new tech terms or
# proper nouns — typos should be fixed).
npm run spell

# Structural lint of top-level markdown docs (README, CLAUDE, FORKING, MAINTENANCE,
# AUDIT_CHECKLIST, COMPARISON + docs/upstream-issues). Catches broken `#anchor`
# links, heading-level skips (h1 → h3), duplicate sibling headings, fenced code
# blocks without a language, and images without alt text. Stylistic rules
# (line-length, table pipe alignment, inline HTML) are disabled — Prettier
# already owns formatting. Config + rationale: `.markdownlint-cli2.jsonc`.
# CMS-authored writing posts under `src/data/escritos/` are intentionally
# excluded (separate authoring conventions).
npm run lint:md

# Unit tests for src/lib/ helpers — fast (~200 ms), catches regressions in
# the markdown renderer's null-byte stash, the i18n pluralization, the
# language-toggle path translator, etc. Cross-browser smoke + axe-core scan
# stay manual (heavy deps, run before release).
npm test
