# Shared editor settings so every contributor (and Sveltia CMS commits) emit
# bytewise-identical whitespace. Pairs with `.gitattributes` (LF enforcement)
# and Prettier (formatting). Without this, an editor on Windows with default
# CRLF + tab indent will dirty every saved file and trip format:check in CI.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 100

# Markdown: trailing spaces are sometimes meaningful (line break) — don't trim.
[*.md]
trim_trailing_whitespace = false

# Makefile-style: tabs are required.
[Makefile]
indent_style = tab
