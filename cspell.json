{
  "version": "0.2",
  "language": "en,es,es-ES",
  "dictionaries": [
    "typescript",
    "node",
    "html",
    "css",
    "html-symbol-entities",
    "fonts",
    "es-es",
    "spanish",
    "project-words"
  ],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./cspell-words.txt",
      "addWords": true
    }
  ],
  "ignorePaths": [
    "node_modules/**",
    ".svelte-kit/**",
    "dist/**",
    "docs/**",
    "coverage/**",
    "static/srcset/**",
    "static/og/**",
    "static/favicon/**",
    "static/admin/**",
    "static/media/**",
    "static/CNAME",
    "lighthouse/**",
    "package-lock.json",
    "package.json",
    "Brewfile",
    "*.lock",
    "*.log",
    "*.svg",
    "*.webp",
    "*.png",
    "*.jpg",
    "*.jpeg",
    "*.gif",
    "*.ico",
    "*.pdf",
    "*.woff2",
    "src/data/**",
    "cspell-words.txt"
  ],
  "ignoreRegExpList": [
    "/(?:0x|#)[0-9a-fA-F]+/",
    "/\\b[A-Z0-9_-]{8,}\\b/",
    "/G-[A-Z0-9]+/",
    "/GTM-[A-Z0-9]+/",
    "/\\bdata:[^'\"\\s]+/",
    "/https?:\\/\\/[^\\s'\"<>]+/",
    "/\\b[a-z0-9-]+\\.(?:webp|png|jpg|jpeg|svg|avif|ico|pdf|html|json|md|ts|tsx|js|mjs|css|woff2)\\b/",
    "/%[a-zA-Z_][a-zA-Z0-9_]*%/",
    "/#[a-zA-Z][a-zA-Z0-9_.-]*/",
    "/[a-zA-Z]+\\.(?:json|ts|tsx|js|mjs|css|md|svelte)#[a-zA-Z][a-zA-Z0-9_.-]*/"
  ]
}
