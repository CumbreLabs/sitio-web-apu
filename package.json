{
  "name": "apu-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "prebuild": "node scripts/pipeline/generate-favicons.mjs && node scripts/pipeline/optimize-images.mjs && node scripts/pipeline/generate-og-images.mjs",
    "build": "vite build",
    "postbuild": "node scripts/postprocess-404.mjs && npx typedoc",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "favicons": "node scripts/pipeline/generate-favicons.mjs",
    "optimize": "node scripts/pipeline/optimize-images.mjs",
    "og:images": "node scripts/pipeline/generate-og-images.mjs",
    "copyright": "node scripts/pipeline/embed-copyright.mjs",
    "check:images": "node scripts/checks/check-image-paths.mjs",
    "check:bundle": "node scripts/checks/check-bundle-size.mjs",
    "check:i18n": "node scripts/checks/check-i18n.mjs",
    "check:cms": "node scripts/checks/check-cms-patterns.mjs",
    "check:fork": "node scripts/checks/check-fork-readiness.mjs",
    "check:required-config": "node scripts/checks/check-required-config.mjs",
    "check:frontmatter": "node scripts/checks/check-frontmatter.mjs",
    "check:ci-parity": "node scripts/checks/check-ci-parity.mjs",
    "check:node-pin": "node scripts/checks/check-node-version-parity.mjs",
    "check:audit-doc": "node scripts/checks/check-audit-checklist.mjs",
    "check:orphan-images": "node scripts/checks/check-orphan-images.mjs",
    "check:nav-slugs": "node scripts/checks/check-nav-slugs.mjs",
    "check:required-paginas": "node scripts/checks/check-required-paginas.mjs",
    "check:portfolio-parity": "node scripts/checks/check-portfolio-parity.mjs",
    "check:album-weight": "node scripts/checks/check-album-weight.mjs",
    "check:canonical-host": "node scripts/checks/check-canonical-host.mjs",
    "check:licenses": "node scripts/checks/check-licenses.mjs",
    "check:actions-pinned": "node scripts/checks/check-actions-pinned.mjs",
    "check:monolingual-build": "node scripts/checks/check-monolingual-build.mjs",
    "check:jsonld": "node scripts/checks/check-jsonld.mjs",
    "audit:all": "npm run check && npm run lint && npm run lint:md && npm run format:check && npm run spell && npm run check:images && npm run check:i18n && npm run check:cms && npm run check:fork && npm run check:required-config && npm run check:frontmatter && npm run check:ci-parity && npm run check:node-pin && npm run check:audit-doc && npm run check:orphan-images && npm run check:nav-slugs && npm run check:required-paginas && npm run check:portfolio-parity && npm run check:album-weight && npm run check:licenses && npm run check:actions-pinned && npm test && npm run build && npm run check:bundle && npm run check:jsonld && npm run check:canonical-host",
    "spell": "cspell '**/*.{ts,svelte,mjs,js,html,yml,yaml,css,md}' --no-progress",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke:cross-browser": "node scripts/cross-browser-smoke.mjs",
    "audit:a11y": "node scripts/axe-scan.mjs",
    "lighthouse:config": "node scripts/pipeline/generate-lighthouse-config.mjs",
    "docs": "typedoc --out docs",
    "prepare": "husky"
  },
  "overrides": {
    "cookie": ">=0.7.0"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/lora": "^5.2.8",
    "defu": "^6.1.7",
    "github-slugger": "^2.0.0",
    "globals": "^17.6.0",
    "lucide-svelte": "^1.0.1",
    "marked": "^18.0.4",
    "marked-gfm-heading-id": "^4.1.4",
    "shiki": "^4.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@cspell/dict-es-es": "^3.0.8",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.7",
    "axe-core": "^4.10.2",
    "cspell": "^10.0.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-svelte": "^3.18.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "license-checker-rseidelsohn": "^5.0.0",
    "markdownlint-cli2": "^0.22.1",
    "mdsvex": "^0.12.5",
    "playwright": "^1.49.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.34.5",
    "svelte": "^5.55.9",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.3.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.9",
    "zod": "^4.4.3"
  }
}
